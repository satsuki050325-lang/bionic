# Bionic Engine Configuration
# Copy this file to .env.local and fill in the values

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Engine
BIONIC_ENGINE_TOKEN=your-secure-random-token
BIONIC_ENGINE_HOST=127.0.0.1
PORT=3001

# Discord
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# Scheduler
BIONIC_SCHEDULER_ENABLED=true
BIONIC_DIGEST_CRON=0 9 * * 1
BIONIC_DIGEST_TIMEZONE=Asia/Tokyo
BIONIC_PROJECT_ID=project_bionic

# Vercel Webhook
VERCEL_WEBHOOK_SECRET=your-webhook-secret
BIONIC_VERCEL_PROJECT_MAP=prj_xxx:medini-api

# Discord Bot
BIONIC_DISCORD_BOT_TOKEN=your-bot-token
BIONIC_DISCORD_CHANNEL_ID=your-channel-id
BIONIC_DISCORD_APPROVER_IDS=discord-user-id-1,discord-user-id-2

# GitHub Webhook (CI failure detection)
GITHUB_WEBHOOK_SECRET=your-github-webhook-secret
BIONIC_GITHUB_REPO_MAP=owner/repo:your-service-id

# Stripe Webhook (payment monitoring)
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret
BIONIC_STRIPE_SERVICE_ID=medini

# Sentry Webhook (error monitoring)
SENTRY_WEBHOOK_SECRET=your-sentry-webhook-secret
BIONIC_SENTRY_SERVICE_ID=medini

# Deployment Watch (Vercel Deploy→Watch→Alert)
BIONIC_DEPLOYMENT_WATCH_MINUTES=30
BIONIC_DEPLOYMENT_THRESHOLD_ERROR_COUNT=5
BIONIC_DEPLOYMENT_THRESHOLD_INCREASE_PERCENT=200

# App
NEXT_PUBLIC_ENGINE_URL=http://localhost:3001
